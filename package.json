{
  "name": "promptlab",
  "version": "1.0.0",
  "description": "PromptLab — Professional Prompt Engineering Studio",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "start": "serve .",
    "dev:serve": "live-server --port=3000 --open=index.html",
    "dev:css": "tailwindcss -i ./css/style.css -o ./css/style.min.css --watch",
    "dev": "npm-run-all --parallel dev:*",
    "build:css": "tailwindcss -i ./css/style.css -o ./css/style.min.css --minify",
    "build:js": "esbuild js/app.js --bundle --minify --external:fs --external:path --external:url --external:module --outfile=js/app.min.js",
    "build": "npm-run-all build:*",
    "lint": "eslint js/*.js --ignore-pattern='*.min.js'",
    "lint:fix": "eslint js/*.js --ignore-pattern='*.min.js' --fix"
  },
  "keywords": [
    "prompt-engineering",
    "llm",
    "templates"
  ],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "harper.js": "^2.0.0",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.2",
    "esbuild": "^0.19.0",
    "eslint": "^10.2.0",
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.2"
  }
}
