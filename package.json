{
  "name": "promptlab",
  "version": "0.1.0",
  "description": "PromptLab — Professional Prompt Engineering Studio",
  "main": "index.html",
  "scripts": {
    "start": "serve .",
    "dev:serve": "live-server --port=3000 --open=index.html",
    "dev:css": "npx @tailwindcss/cli -i ./css/style.css -o ./css/style.min.css --watch",
    "dev": "npm-run-all --parallel dev:*",
    "build:css": "npx @tailwindcss/cli -i ./css/style.css -o ./css/style.min.css --minify",
    "build:js": "esbuild js/app.js --bundle --minify --outfile=js/app.min.js",
    "build": "npm-run-all build:*"
  },
  "keywords": [
    "prompt-engineering",
    "llm",
    "templates"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "jquery": "^4.0.0",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "esbuild": "^0.19.0",
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.2"
  }
}
